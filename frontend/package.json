{
  "name": "secgraph-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:android": "tsc -b && VITE_API_URL=${VITE_API_URL:-http://10.0.2.2:8080/api} vite build",
    "build:phone": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "android:sync": "npm run build:android && cap sync android",
    "android:sync:phone": "npm run build:phone && cap sync android",
    "android:open": "npm run android:sync && cap open android",
    "android:open:phone": "npm run android:sync:phone && cap open android",
    "android:run": "npm run android:sync && cap run android",
    "android:run:phone": "npm run android:sync:phone && cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "axios": "1.15.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-force-graph-2d": "^1.26.7",
    "react-router-dom": "^7.6.1",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "overrides": {
    "axios": "1.15.1",
    "follow-redirects": "1.16.0",
    "form-data": "4.0.5"
  }
}
